# Docker registry
KAMAL_REGISTRY_PASSWORD=your-registry-password

# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=

# Generate with: openssl rand -base64 32
TOTP_VAULT_KEY=

# PostgreSQL password (used in DATABASE_URL below)
POSTGRES_PASSWORD=change-me-to-a-secure-password

# Database connection strings
# The hostnames (plausible-db, plausible-events-db) match Kamal's
# accessory container naming: <service>-<accessory_name>
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@plausible-db:5432/plausible_db

# Uncomment for SMTP auth:
# SMTP_USER_NAME=
# SMTP_USER_PWD=

# Uncomment for Google Search Console:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Uncomment for MaxMind GeoIP (city-level geolocation):
# MAXMIND_LICENSE_KEY=
# MAXMIND_EDITION=GeoLite2-City
