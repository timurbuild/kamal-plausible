# === Deployment Configuration ===
SERVER_IP=
PLAUSIBLE_HOST=plausible.example.com
REGISTRY_USERNAME=

# === Docker Registry ===
KAMAL_REGISTRY_PASSWORD=

# === Plausible Secrets (auto-generated by `just init`) ===
SECRET_KEY_BASE=
TOTP_VAULT_KEY=
POSTGRES_PASSWORD=

# === Database Connection ===
# Hostnames match Kamal's accessory container naming: <service>-<accessory>
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@plausible-db:5432/plausible_db

# === Optional: Email (needed for user invitations and password resets) ===
# SMTP_HOST_ADDR=smtp.example.com
# SMTP_HOST_PORT=587
# SMTP_HOST_SSL_ENABLED=true
# SMTP_USER_NAME=
# SMTP_USER_PWD=
# MAILER_EMAIL=plausible@example.com
# MAILER_NAME=Plausible Analytics

# === Optional: Google Search Console ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === Optional: MaxMind GeoIP (city-level geolocation) ===
# MAXMIND_LICENSE_KEY=
# MAXMIND_EDITION=GeoLite2-City
